{
    "name": "DeepForest Training",
    "image": "ghcr.io/tcapelle/dev_box:latest",

    "containerEnv": {
      "WANDB_API_KEY": "${localEnv:WANDB_API_KEY}",
      "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
      "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
      "HF_API_TOKEN": "${localEnv:HF_API_TOKEN}",
      "HF_TOKEN": "${localEnv:HF_API_TOKEN}",
      "MODAL_TOKEN_ID": "${localEnv:MODAL_TOKEN_ID}",
      "MODAL_TOKEN_SECRET": "${localEnv:MODAL_TOKEN_SECRET}"
    },

    "postCreateCommand": "bash .devcontainer/setup.sh",

    "customizations": {
      "cursor": {
        "extensions": [
          "ms-python.python",
          "ms-toolsai.jupyter"
        ],
        "settings": {
          "terminal.integrated.defaultProfile.linux": "zsh"
        }
      }
    }
  }
